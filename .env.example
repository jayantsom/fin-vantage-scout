# Copy this file to .env and fill in your values.
# .env is git-ignored — this file (.env.example) is safe to commit.

# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key (free tier at https://console.groq.com)
# Used for the primary LLM provider (LLaMA 3 models via Groq cloud).
# If unset or invalid, the system falls back to local Ollama automatically.
GROQ_API_KEY=your_groq_api_key_here

# ── Optional (Alpha Vantage — secondary data source) ──────────────────────────

# Alpha Vantage API key (free tier at https://www.alphavantage.co/support/#api-key)
# No credit card required.  Free tier: 25 requests/day, 5 requests/minute.
#
# What it's used for:
#   1. Fundamentals fallback — if yfinance is missing a field (currentRatio,
#      debtToEquity, ROE, grossMargins) for a ticker, we try the AV OVERVIEW
#      endpoint before returning None.
#   2. RSI signal — 14-day RSI is fetched from AV as an independent momentum
#      indicator and added to MomentumResult.rsi_14.
#
# Quota safety: each ticker consumes up to 2 AV calls (OVERVIEW + RSI).
# The /analyze endpoint enforces a cap of 10 tickers per run when this key
# is set (configurable via ALPHA_VANTAGE_TICKERS_PER_RUN in config.py).
#
# If this key is unset, all AV calls are silently skipped — the app still
# works fully using yfinance alone.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ── Optional (Ollama fallback) ─────────────────────────────────────────────────

# Ollama runs locally — no key needed, but you must have it installed and the
# model pulled before the fallback will work:
#   ollama pull llama3.2:3b
#
# Install Ollama: https://ollama.com
