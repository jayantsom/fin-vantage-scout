# Copy this file to .env and fill in your values.
# .env is git-ignored — this file (.env.example) is safe to commit.

# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key (free tier at https://console.groq.com)
# Used for the primary LLM provider (LLaMA 3 models via Groq cloud).
# If unset or invalid, the system falls back to local Ollama automatically.
GROQ_API_KEY=your_groq_api_key_here

# ── Optional (Ollama fallback) ─────────────────────────────────────────────────

# Ollama runs locally — no key needed, but you must have it installed and the
# model pulled before the fallback will work:
#   ollama pull llama3.2:3b
#
# Install Ollama: https://ollama.com
