# =============================================================================
# fin-vantage-scout .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & secrets  (NEVER commit these)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Profiling
*.prof

# -----------------------------------------------------------------------------
# uv / virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# uv lock is intentionally committed — remove this line if you don't want that
# uv.lock

# -----------------------------------------------------------------------------
# Project-specific runtime artifacts
# -----------------------------------------------------------------------------

# SQLite cache (auto-generated, can be regenerated on demand)
*.db
*.sqlite
*.sqlite3

# Signal validation outputs
tests/momentum/
outputs/

# Streamlit cache
.streamlit/

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-workspace

# Spyder
.spyderproject.proj
.spyproject

# Rope
.ropeproject

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# Linux
*~

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.orig

# -----------------------------------------------------------------------------
# LangSmith / LangChain tracing (if enabled)
# -----------------------------------------------------------------------------
.langchain/
